{% comment %}
  FAQ Section - Shopify Liquid
  Compatible with Shopify 2.0 themes
{% endcomment %}

{{ 'section-faq.css' | asset_url | stylesheet_tag }}

<div class="faq-section-wrapper" style="
  --faq-bg-color: {{ section.settings.background_color }};
  --faq-left-bg: {{ section.settings.left_bg_color }};
  --faq-right-bg: {{ section.settings.right_bg_color }};
  --faq-text-color: {{ section.settings.text_color }};
  --faq-heading-color: {{ section.settings.heading_color }};
  --faq-question-bg: {{ section.settings.question_bg_color }};
  --faq-question-text: {{ section.settings.question_text_color }};
  --faq-answer-bg: {{ section.settings.answer_bg_color }};
  --faq-answer-text: {{ section.settings.answer_text_color }};
  --faq-border-color: {{ section.settings.border_color }};
  --faq-icon-color: {{ section.settings.icon_color }};
  --faq-heading-size: {{ section.settings.heading_font_size }}px;
  --faq-question-size: {{ section.settings.question_font_size }}px;
  --faq-answer-size: {{ section.settings.answer_font_size }}px;
  --faq-left-max-width: {{ section.settings.left_max_width }}px;
  --faq-padding-top: {{ section.settings.padding_top }}px;
  --faq-padding-bottom: {{ section.settings.padding_bottom }}px;
  --faq-border-radius: {{ section.settings.border_radius }}px;
  --faq-item-spacing: {{ section.settings.item_spacing }}px;
  --faq-container-max-width: {{ section.settings.container_max_width }}px;
  --faq-image-width: {{ section.settings.image_width }}%;
  --faq-image-height: {{ section.settings.image_height }}px;
">
  <div class="faq-container">
    <div class="faq-left">
      {% if section.settings.show_heading %}
        <h2 class="faq-heading">{{ section.settings.heading_text }}</h2>
      {% endif %}

      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="faq-item {% if forloop.first and section.settings.first_item_open %}active{% endif %}" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="{% if forloop.first and section.settings.first_item_open %}true{% else %}false{% endif %}">
              {{ block.settings.question }}
              <span class="faq-icon">{% if forloop.first and section.settings.first_item_open %}–{% else %}+{% endif %}</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-content">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="faq-placeholder">
          <p>Add FAQ blocks to display questions and answers.</p>
        </div>
      {% endif %}
    </div>

    {% if section.settings.show_image %}
      <div class="faq-right">
        {% if section.settings.right_image != blank %}
          {{ section.settings.right_image | image_url: width: 1200 | image_tag: 
            loading: 'lazy',
            alt: section.settings.image_alt_text,
            class: 'faq-image'
          }}
        {% else %}
          <div class="faq-placeholder-image">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqItems = document.querySelectorAll('.faq-item');
    const accordionBehavior = {{ section.settings.accordion_behavior | json }};

    faqItems.forEach(item => {
      const button = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      const answer = item.querySelector('.faq-answer');

      button.addEventListener('click', () => {
        const isActive = item.classList.contains('active');

        if (accordionBehavior === 'single') {
          // Close all other items
          faqItems.forEach(i => {
            if (i !== item) {
              i.classList.remove('active');
              i.querySelector('.faq-icon').textContent = '+';
              i.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
            }
          });
        }

        // Toggle current item
        if (!isActive) {
          item.classList.add('active');
          icon.textContent = '–';
          button.setAttribute('aria-expanded', 'true');
        } else {
          item.classList.remove('active');
          icon.textContent = '+';
          button.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
</script>

<style>
  .faq-section-wrapper {
    background-color: var(--faq-bg-color);
    padding-top: var(--faq-padding-top);
    padding-bottom: var(--faq-padding-bottom);
  }

  .faq-container {
    display: flex;
    flex-wrap: wrap;
    min-height: {{ section.settings.min_height }}vh;
    max-width: var(--faq-container-max-width);
    margin: 0 auto;
  }

  .faq-left {
    flex: 1;
    padding: {{ section.settings.left_padding_top }}px {{ section.settings.left_padding_right }}px {{ section.settings.left_padding_bottom }}px {{ section.settings.left_padding_left }}px;
    background-color: var(--faq-left-bg);
    max-width: var(--faq-left-max-width);
  }

  .faq-heading {
    font-size: var(--faq-heading-size);
    color: var(--faq-heading-color);
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    text-align: {{ section.settings.heading_alignment }};
  }

  .faq-item {
    border: {{ section.settings.border_width }}px solid var(--faq-border-color);
    border-radius: var(--faq-border-radius);
    margin-bottom: var(--faq-item-spacing);
    background-color: var(--faq-question-bg);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  {% if section.settings.hover_effect %}
  .faq-item:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  {% endif %}

  .faq-question {
    width: 100%;
    padding: {{ section.settings.question_padding_top }}px {{ section.settings.question_padding_right }}px {{ section.settings.question_padding_bottom }}px {{ section.settings.question_padding_left }}px;
    background-color: var(--faq-question-bg);
    border: none;
    text-align: left;
    font-size: var(--faq-question-size);
    font-weight: {{ section.settings.question_font_weight }};
    color: var(--faq-question-text);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background-color 0.3s ease;
  }

  .faq-question:hover {
    opacity: 0.9;
  }

  .faq-icon {
    font-size: {{ section.settings.icon_size }}px;
    margin-left: 10px;
    transition: transform 0.3s ease;
    color: var(--faq-icon-color);
    font-weight: {{ section.settings.icon_font_weight }};
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height {{ section.settings.animation_speed }}ms ease;
    background-color: var(--faq-answer-bg);
  }

  .faq-answer-content {
    padding: {{ section.settings.answer_padding_top }}px {{ section.settings.answer_padding_right }}px {{ section.settings.answer_padding_bottom }}px {{ section.settings.answer_padding_left }}px;
    font-size: var(--faq-answer-size);
    color: var(--faq-answer-text);
    line-height: {{ section.settings.answer_line_height }};
  }

  .faq-item.active .faq-answer {
    max-height: {{ section.settings.answer_max_height }}px;
  }

  {% if section.settings.rotate_icon %}
  .faq-item.active .faq-icon {
    transform: rotate(180deg);
  }
  {% endif %}

  .faq-right {
    flex: 1;
    background-color: var(--faq-right-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    {% if section.settings.right_min_width > 0 %}
    min-width: {{ section.settings.right_min_width }}px;
    {% endif %}
  }

  .faq-right img,
  .faq-placeholder-image {
    width: var(--faq-image-width);
    height: var(--faq-image-height);
    object-fit: {{ section.settings.image_fit }};
  }

  .faq-placeholder {
    padding: 40px;
    text-align: center;
    color: #999;
  }

  /* Responsive Styles */
  @media (max-width: 992px) {
    .faq-container {
      flex-direction: {{ section.settings.mobile_layout }};
    }

    .faq-left, .faq-right {
      max-width: 100%;
    }

    .faq-left {
      padding: {{ section.settings.mobile_padding }}px;
    }

    .faq-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .faq-question {
      font-size: {{ section.settings.question_font_size_mobile }}px;
      padding: {{ section.settings.question_padding_mobile }}px;
    }

    .faq-answer-content {
      font-size: {{ section.settings.answer_font_size_mobile }}px;
      padding: {{ section.settings.answer_padding_mobile }}px;
    }

    .faq-icon {
      font-size: {{ section.settings.icon_size_mobile }}px;
    }
  }

  @media (max-width: 576px) {
    .faq-heading {
      font-size: {{ section.settings.heading_font_size_small }}px;
    }

    .faq-question {
      font-size: {{ section.settings.question_font_size_small }}px;
    }

    .faq-answer-content {
      font-size: {{ section.settings.answer_font_size_small }}px;
    }
  }
</style>

