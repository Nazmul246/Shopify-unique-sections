{% comment %}
  Section: Onda Provisions – Our Values
  Theme: Serenity (Shopify)
  All settings are dynamic via schema
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign bg_color         = section.settings.background_color
  assign grid_line_color  = section.settings.grid_line_color
  assign glow_color       = section.settings.glow_color
  assign eyebrow_color    = section.settings.eyebrow_color
  assign title_color      = section.settings.title_color
  assign italic_color     = section.settings.italic_color
  assign intro_color      = section.settings.intro_color
  assign card_bg          = section.settings.card_background_color
  assign card_hover_bg    = section.settings.card_hover_background_color
  assign card_name_color  = section.settings.card_name_color
  assign card_text_color  = section.settings.card_text_color
  assign card_text_hover  = section.settings.card_text_hover_color
  assign icon_border      = section.settings.icon_border_color
  assign bg_num_color     = section.settings.bg_number_color
  assign pledge_bg        = section.settings.pledge_background_color
  assign pledge_border    = section.settings.pledge_border_color
  assign pledge_icon_bg   = section.settings.pledge_icon_bg
  assign pledge_icon_color = section.settings.pledge_icon_color
  assign pledge_text_color = section.settings.pledge_text_color
  assign pledge_strong    = section.settings.pledge_strong_color
  assign pledge_tag_color = section.settings.pledge_tag_color
  assign section_padding_top    = section.settings.padding_top
  assign section_padding_bottom = section.settings.padding_bottom
  assign section_padding_h      = section.settings.padding_horizontal
  assign max_width        = section.settings.max_width
  assign title_size       = section.settings.title_font_size
  assign eyebrow_size     = section.settings.eyebrow_font_size
  assign intro_size       = section.settings.intro_font_size
  assign card_name_size   = section.settings.card_name_font_size
  assign card_text_size   = section.settings.card_text_font_size
  assign pledge_text_size = section.settings.pledge_text_font_size
  assign pledge_tag_size  = section.settings.pledge_tag_font_size
  assign card_padding_v   = section.settings.card_padding_vertical
  assign card_padding_h   = section.settings.card_padding_horizontal
  assign show_pledge      = section.settings.show_pledge
  assign show_grid_pattern = section.settings.show_grid_pattern
  assign show_glow        = section.settings.show_glow
  assign show_bg_numbers  = section.settings.show_bg_numbers
  assign columns_desktop  = section.settings.columns_desktop
  assign eyebrow_text     = section.settings.eyebrow_text
  assign title_line1      = section.settings.title_line1
  assign title_line2      = section.settings.title_line2
  assign intro_text       = section.settings.intro_text
  assign pledge_text      = section.settings.pledge_text
  assign pledge_label     = section.settings.pledge_label

  assign accent1 = section.settings.accent_color_1
  assign accent2 = section.settings.accent_color_2
  assign accent3 = section.settings.accent_color_3
  assign accent4 = section.settings.accent_color_4
-%}

<style>
  #shopify-section-{{ section_id }} {
    --ov-bg:           {{ bg_color }};
    --ov-accent1:      {{ accent1 }};
    --ov-accent2:      {{ accent2 }};
    --ov-accent3:      {{ accent3 }};
    --ov-accent4:      {{ accent4 }};
    --ov-eyebrow:      {{ eyebrow_color }};
    --ov-title:        {{ title_color }};
    --ov-italic:       {{ italic_color }};
    --ov-intro:        {{ intro_color }};
    --ov-card-bg:      {{ card_bg }};
    --ov-card-hover:   {{ card_hover_bg }};
    --ov-card-name:    {{ card_name_color }};
    --ov-card-text:    {{ card_text_color }};
    --ov-card-text-hover: {{ card_text_hover }};
    --ov-icon-border:  {{ icon_border }};
    --ov-bg-num:       {{ bg_num_color }};
    --ov-grid-line:    {{ grid_line_color }};
    --ov-glow:         {{ glow_color }};
    --ov-pledge-bg:    {{ pledge_bg }};
    --ov-pledge-border: {{ pledge_border }};
    --ov-pledge-icon-bg: {{ pledge_icon_bg }};
    --ov-pledge-icon:  {{ pledge_icon_color }};
    --ov-pledge-text:  {{ pledge_text_color }};
    --ov-pledge-strong: {{ pledge_strong }};
    --ov-pledge-tag:   {{ pledge_tag_color }};

    --ov-title-size:      {{ title_size }}px;
    --ov-eyebrow-size:    {{ eyebrow_size }}px;
    --ov-intro-size:      {{ intro_size }}px;
    --ov-card-name-size:  {{ card_name_size }}px;
    --ov-card-text-size:  {{ card_text_size }}px;
    --ov-pledge-text-size: {{ pledge_text_size }}px;
    --ov-pledge-tag-size: {{ pledge_tag_size }}px;

    --ov-pad-top:     {{ section_padding_top }}px;
    --ov-pad-bottom:  {{ section_padding_bottom }}px;
    --ov-pad-h:       {{ section_padding_h }}vw;
    --ov-max-width:   {{ max_width }}px;
    --ov-card-pad-v:  {{ card_padding_v }}px;
    --ov-card-pad-h:  {{ card_padding_h }}px;
    --ov-columns:     {{ columns_desktop }};
  }

  .ov-section {
    background: var(--ov-bg);
    padding: var(--ov-pad-top) var(--ov-pad-h) var(--ov-pad-bottom);
    position: relative;
    overflow: hidden;
  }

  .ov-section__inner {
    max-width: var(--ov-max-width);
    margin: 0 auto;
  }

  {% if show_grid_pattern %}
  .ov-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--ov-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--ov-grid-line) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }
  {% endif %}

  {% if show_glow %}
  .ov-section::after {
    content: '';
    position: absolute;
    top: -10rem; right: -10rem;
    width: 35rem; height: 35rem;
    border-radius: 50%;
    background: radial-gradient(circle, var(--ov-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  {% endif %}

  /* ── HEADER ── */
  .ov-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 5rem;
    position: relative;
    z-index: 2;
  }

  .ov-eyebrow {
    font-size: var(--ov-eyebrow-size);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ov-eyebrow);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.2rem;
  }
  .ov-eyebrow::before {
    content: '';
    width: 2rem; height: 1px;
    background: var(--ov-eyebrow);
    flex-shrink: 0;
  }

  .ov-title {
    font-size: var(--ov-title-size);
    font-weight: 300;
    line-height: 1.05;
    color: var(--ov-title);
  }
  .ov-title em {
    font-style: italic;
    color: var(--ov-italic);
  }

  .ov-intro {
    font-size: var(--ov-intro-size);
    line-height: 1.75;
    color: var(--ov-intro);
    font-weight: 300;
    max-width: 46ch;
    align-self: end;
  }

  /* ── GRID ── */
  .ov-grid {
    display: grid;
    grid-template-columns: repeat(var(--ov-columns), 1fr);
    gap: 1px;
    background: var(--ov-grid-line);
    position: relative;
    z-index: 2;
  }

  /* ── CARD ── */
  .ov-card {
    background: var(--ov-card-bg);
    padding: var(--ov-card-pad-v) var(--ov-card-pad-h);
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: background 0.4s;
    display: flex;
    flex-direction: column;
  }
  .ov-card:hover { background: var(--ov-card-hover); }

  .ov-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .ov-card:hover::before { transform: scaleX(1); }

  .ov-card:nth-child(1)::before { background: var(--ov-accent1); }
  .ov-card:nth-child(2)::before { background: var(--ov-accent2); }
  .ov-card:nth-child(3)::before { background: var(--ov-accent3); }
  .ov-card:nth-child(4)::before { background: var(--ov-accent4); }

  {% if show_bg_numbers %}
  .ov-card__bg-num {
    position: absolute;
    bottom: -1.5rem; right: 1rem;
    font-size: 9rem;
    font-weight: 300;
    color: var(--ov-bg-num);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.4s;
    opacity: 1;
  }
  {% else %}
  .ov-card__bg-num { display: none; }
  {% endif %}

  .ov-card__icon {
    width: 5rem; height: 5rem;
    border: 1px solid var(--ov-icon-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    flex-shrink: 0;
    transition: border-color 0.3s, background 0.3s;
  }
  .ov-card:nth-child(1):hover .ov-card__icon { border-color: var(--ov-accent1); background: color-mix(in srgb, var(--ov-accent1) 15%, transparent); }
  .ov-card:nth-child(2):hover .ov-card__icon { border-color: var(--ov-accent2); background: color-mix(in srgb, var(--ov-accent2) 12%, transparent); }
  .ov-card:nth-child(3):hover .ov-card__icon { border-color: var(--ov-accent3); background: color-mix(in srgb, var(--ov-accent3) 10%, transparent); }
  .ov-card:nth-child(4):hover .ov-card__icon { border-color: var(--ov-accent4); background: color-mix(in srgb, var(--ov-accent4) 15%, transparent); }

  .ov-card__icon svg {
    width: 3rem; height: 3rem;
    color: var(--ov-icon-border);
    transition: color 0.3s;
  }
  .ov-card:nth-child(1):hover .ov-card__icon svg { color: var(--ov-accent1); }
  .ov-card:nth-child(2):hover .ov-card__icon svg { color: var(--ov-accent2); }
  .ov-card:nth-child(3):hover .ov-card__icon svg { color: var(--ov-accent3); }
  .ov-card:nth-child(4):hover .ov-card__icon svg { color: var(--ov-accent4); }

  .ov-card__name {
    font-size: var(--ov-card-name-size);
    font-weight: 400;
    color: var(--ov-card-name);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .ov-card__text {
    font-size: var(--ov-card-text-size);
    line-height: 1.72;
    color: var(--ov-card-text);
    font-weight: 300;
    flex: 1;
    transition: color 0.3s;
  }
  .ov-card:hover .ov-card__text { color: var(--ov-card-text-hover); }

  /* ── PLEDGE ── */
  {% if show_pledge %}
  .ov-pledge {
    margin-top: 4rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem 3rem;
    border: 1px solid var(--ov-pledge-border);
    position: relative;
    z-index: 2;
    background: var(--ov-pledge-bg);
    flex-wrap: wrap;
  }

  .ov-pledge__icon {
    flex-shrink: 0;
    width: 3.5rem; height: 3.5rem;
    border-radius: 50%;
    background: var(--ov-pledge-icon-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ov-pledge__icon svg { width: 1.4rem; height: 1.4rem; color: var(--ov-pledge-icon); }

  .ov-pledge__text {
    font-style: italic;
    font-size: var(--ov-pledge-text-size);
    color: var(--ov-pledge-text);
    font-weight: 300;
    line-height: 1.5;
    flex: 1;
    min-width: 200px;
  }
  .ov-pledge__text strong {
    color: var(--ov-pledge-strong);
    font-style: normal;
    font-weight: 400;
  }

  .ov-pledge__divider {
    width: 1px; height: 3rem;
    background: var(--ov-pledge-border);
    flex-shrink: 0;
  }

  .ov-pledge__tag {
    font-size: var(--ov-pledge-tag-size);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ov-pledge-tag);
    font-weight: 500;
    white-space: nowrap;
  }
  {% else %}
  .ov-pledge { display: none !important; }
  {% endif %}

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .ov-grid { --ov-columns: 2; }
  }

  @media (max-width: 768px) {
    .ov-header {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 3rem;
    }
    .ov-intro { max-width: 100%; }
    .ov-grid { --ov-columns: 2; }
    .ov-pledge__divider { display: none; }
    .ov-pledge { padding: 2rem 1.5rem; }
  }

  @media (max-width: 540px) {
    .ov-grid { --ov-columns: 1; }
    .ov-section { padding: calc(var(--ov-pad-top) * 0.7) 5vw calc(var(--ov-pad-bottom) * 0.7); }
    .ov-title { font-size: calc(var(--ov-title-size) * 0.72); }
  }
</style>

<section class="ov-section" id="ov-{{ section_id }}">
  <div class="ov-section__inner">

    <div class="ov-header">
      <div>
        <p class="ov-eyebrow">{{ eyebrow_text }}</p>
        <h2 class="ov-title">
          {{ title_line1 }}<br>
          <em>{{ title_line2 }}</em>
        </h2>
      </div>
      <p class="ov-intro">{{ intro_text }}</p>
    </div>

    <div class="ov-grid">
      {% for block in section.blocks %}
        {% if block.type == 'value_card' %}
          <div class="ov-card" {{ block.shopify_attributes }}>
            {% if show_bg_numbers %}
              <span class="ov-card__bg-num" aria-hidden="true">0{{ forloop.index }}</span>
            {% endif %}

            <div class="ov-card__icon" aria-hidden="true">
              {% case block.settings.icon %}
                {% when 'shield' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                {% when 'clock' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 6v6l4 2"/>
                  </svg>
                {% when 'check' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M9 11l3 3L22 4"/>
                    <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                  </svg>
                {% when 'heart' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                  </svg>
                {% when 'leaf' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
                    <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
                  </svg>
                {% when 'star' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                {% when 'truck' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="1" y="3" width="15" height="13"/>
                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                    <circle cx="5.5" cy="18.5" r="2.5"/>
                    <circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                {% when 'map-pin' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 8v4m0 4h.01"/>
                  </svg>
              {% endcase %}
            </div>

            <h3 class="ov-card__name">{{ block.settings.name }}</h3>
            <p class="ov-card__text">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if show_pledge %}
      <div class="ov-pledge">
        <div class="ov-pledge__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <p class="ov-pledge__text">{{ pledge_text }}</p>
        <div class="ov-pledge__divider" aria-hidden="true"></div>
        <p class="ov-pledge__tag">{{ pledge_label }}</p>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Onda – Our Values",
  "tag": "section",
  "class": "ov-section-wrapper",
  "settings": [

    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 800,
      "max": 1800,
      "step": 20,
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal Padding (vw)",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "card_padding_vertical",
      "label": "Card Padding Vertical (px)",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "card_padding_horizontal",
      "label": "Card Padding Horizontal (px)",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 40
    },

    {
      "type": "header",
      "content": "Section Header Text"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "title_line1",
      "label": "Title Line 1",
      "default": "What We"
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Title Line 2 (italic)",
      "default": "Stand For"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro Paragraph",
      "default": "Every decision we make — from the farms we source from to the containers we pack in — comes back to four core beliefs that drive everything at Onda Provisions."
    },

    {
      "type": "header",
      "content": "Pledge Bar"
    },
    {
      "type": "checkbox",
      "id": "show_pledge",
      "label": "Show Pledge Bar",
      "default": true
    },
    {
      "type": "textarea",
      "id": "pledge_text",
      "label": "Pledge Text (use <strong> for bold)",
      "default": "<strong>Our promise:</strong> If you're not completely satisfied with your Onda delivery, we'll make it right — no questions asked. That's our commitment to you, every single week."
    },
    {
      "type": "text",
      "id": "pledge_label",
      "label": "Pledge Tag Label",
      "default": "The Onda Promise"
    },

    {
      "type": "header",
      "content": "Background & Decorative"
    },
    {
      "type": "checkbox",
      "id": "show_grid_pattern",
      "label": "Show Background Grid Pattern",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Show Corner Glow",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bg_numbers",
      "label": "Show Background Card Numbers",
      "default": true
    },

    {
      "type": "header",
      "content": "Colors – Section"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background",
      "default": "#1a1a18"
    },
    {
      "type": "color",
      "id": "grid_line_color",
      "label": "Grid Line / Divider Color",
      "default": "#2d2d2b"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Corner Glow Color",
      "default": "#03414a"
    },

    {
      "type": "header",
      "content": "Colors – Accent"
    },
    {
      "type": "color",
      "id": "accent_color_1",
      "label": "Card 1 Accent",
      "default": "#036774"
    },
    {
      "type": "color",
      "id": "accent_color_2",
      "label": "Card 2 Accent",
      "default": "#ed7009"
    },
    {
      "type": "color",
      "id": "accent_color_3",
      "label": "Card 3 Accent",
      "default": "#c6c3b8"
    },
    {
      "type": "color",
      "id": "accent_color_4",
      "label": "Card 4 Accent",
      "default": "#036774"
    },

    {
      "type": "header",
      "content": "Colors – Header"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#ed7009"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff"
    },
