<ugc-video-slider-{{ ai_gen_id }}
  class="ai-ugc-video-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-ugc-video-slider-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-ugc-video-slider-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-ugc-video-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-ugc-video-slider-track-{{ ai_gen_id }}" data-track>
        {% for i in (1..6) %}
          {% liquid
            assign video_key     = 'video_' | append: i
            assign video_url_key = 'video_url_' | append: i
            assign video         = block.settings[video_key]
            assign video_url     = block.settings[video_url_key]

            comment
              "video" type returns a Shopify video object with a .sources array.
              We must extract the actual CDN URL from that array.
              Prefer mp4 format; fall back to the first available source.
              If no upload, fall back to the plain URL string from video_url field.
            endcomment

            assign resolved_src = nil

            if video != blank
              comment Pick mp4 first, then fall back to sources[0]
              endcomment
              assign resolved_src = video.sources[0].url
              for source in video.sources
                if source.format == 'mp4'
                  assign resolved_src = source.url
                  break
                endif
              endfor
            elsif video_url != blank
              assign resolved_src = video_url
            endif
          %}

          <div class="ai-ugc-video-slider-slide-{{ ai_gen_id }}">
            {% if resolved_src != blank %}
              <video
                src="{{ resolved_src }}"
                {% if block.settings.autoplay %}autoplay{% endif %}
                {% if block.settings.loop %}loop{% endif %}
                {% if block.settings.muted %}muted{% endif %}
                playsinline
                {% if block.settings.controls %}controls{% endif %}
              ></video>
            {% else %}
              <div class="ai-ugc-video-slider-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
                <div class="ai-ugc-video-slider-empty-state-{{ ai_gen_id }}">
                  Add video {{ i }}
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <button
        class="ai-ugc-video-slider-nav-{{ ai_gen_id }} ai-ugc-video-slider-nav-prev-{{ ai_gen_id }}"
        data-prev
        aria-label="Previous video"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-ugc-video-slider-nav-{{ ai_gen_id }} ai-ugc-video-slider-nav-next-{{ ai_gen_id }}"
        data-next
        aria-label="Next video"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</ugc-video-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class UgcVideoSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.videosPerView = {{ block.settings.videos_per_view }};
        this.videosPerViewMobile = {{ block.settings.videos_per_view_mobile }};
        this.videoGap = {{ block.settings.video_gap }};
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.slides = this.querySelectorAll('.ai-ugc-video-slider-slide-{{ ai_gen_id }}');
        this.totalSlides = this.slides.length;

        this.setupEventListeners();
        this.updateButtons();
        this.handleResize();

        window.addEventListener('resize', () => this.handleResize());
      }

      handleResize() {
        this.isMobile = window.innerWidth < 750;
        this.currentVideosPerView = this.isMobile ? this.videosPerViewMobile : this.videosPerView;
        this.maxIndex = Math.max(0, this.totalSlides - this.currentVideosPerView);

        if (this.currentIndex > this.maxIndex) {
          this.currentIndex = this.maxIndex;
        }

        this.updateSlider();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      updateSlider() {
        const slideWidth = this.slides[0].offsetWidth;
        const offset = -(this.currentIndex * (slideWidth + this.videoGap));
        this.track.style.transform = `translateX(${offset}px)`;
        this.updateButtons();
      }

      updateButtons() {
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= this.maxIndex;
      }
    }

    customElements.define('ugc-video-slider-{{ ai_gen_id }}', UgcVideoSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
