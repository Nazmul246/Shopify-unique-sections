{% comment %}
  Category Slider Section
  - Manual navigation arrows (top-right, same line as heading)
  - Staggered card heights (middle card taller)
  - Image cards as blocks with title + shop now button
  - Fully responsive, all settings editable from Customize
{% endcomment %}

{%- assign section_id = 'cs-' | append: section.id -%}

<style>
  #{{ section_id }} {
    --cs-bg-color:              {{ section.settings.bg_color }};
    --cs-heading-color:         {{ section.settings.heading_color }};
    --cs-accent-color:          {{ section.settings.accent_color }};
    --cs-heading-size:          {{ section.settings.heading_size }}px;
    --cs-accent-size:           {{ section.settings.accent_size }}px;
    --cs-card-gap:              {{ section.settings.card_gap }}px;
    --cs-card-height:           {{ section.settings.card_height }}px;
    --cs-card-height-center:    {{ section.settings.card_height_center }}px;
    --cs-card-border-radius:    {{ section.settings.card_border_radius }}px;
    --cs-pt:                    {{ section.settings.padding_top }}px;
    --cs-pb:                    {{ section.settings.padding_bottom }}px;
    --cs-section-width:         {{ section.settings.section_width }};
    --cs-cards-desktop:         {{ section.settings.cards_visible_desktop }};
    --cs-btn-bg:                {{ section.settings.btn_bg_color }};
    --cs-btn-color:             {{ section.settings.btn_text_color }};
    --cs-title-color:           {{ section.settings.card_title_color }};
    --cs-title-size:            {{ section.settings.card_title_size }}px;
    --cs-arrow-color:           {{ section.settings.arrow_color }};
    --cs-arrow-border:          {{ section.settings.arrow_border_color }};
  }

  #{{ section_id }} .cs-section {
    background-color: var(--cs-bg-color);
    padding-top:    var(--cs-pt);
    padding-bottom: var(--cs-pb);
  }

  #{{ section_id }} .cs-inner {
    max-width: var(--cs-section-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Header row ── */
  #{{ section_id }} .cs-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: {{ section.settings.heading_bottom_gap }}px;
    gap: 16px;
  }

  #{{ section_id }} .cs-headings {
    flex: 1;
  }

  #{{ section_id }} .cs-heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--cs-heading-size);
    font-weight: 700;
    color: var(--cs-heading-color);
    margin: 0 0 4px;
    line-height: 1.2;
  }

  #{{ section_id }} .cs-accent {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--cs-accent-size);
    font-weight: 700;
    font-style: italic;
    color: var(--cs-accent-color);
    margin: 0;
    line-height: 1.2;
  }

  /* ── Arrow buttons ── */
  #{{ section_id }} .cs-arrows {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  #{{ section_id }} .cs-arrow {
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--cs-arrow-border);
    border-radius: 50%;
    background: transparent;
    color: var(--cs-arrow-color);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  #{{ section_id }} .cs-arrow:hover {
    background: var(--cs-arrow-color);
    color: var(--cs-bg-color);
    border-color: var(--cs-arrow-color);
  }

  #{{ section_id }} .cs-arrow.is-disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  #{{ section_id }} .cs-arrow svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Slider viewport ── */
  #{{ section_id }} .cs-viewport {
    overflow: hidden;
  }

  #{{ section_id }} .cs-track {
    display: flex;
    align-items: flex-end;
    gap: var(--cs-card-gap);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* ── Card ── */
  #{{ section_id }} .cs-card {
    flex: 0 0 calc((100% - (var(--cs-cards-desktop) - 1) * var(--cs-card-gap)) / var(--cs-cards-desktop));
    width: calc((100% - (var(--cs-cards-desktop) - 1) * var(--cs-card-gap)) / var(--cs-cards-desktop));
    height: var(--cs-card-height);
    border-radius: var(--cs-card-border-radius);
    overflow: hidden;
    position: relative;
    display: block;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Center card taller effect — applied via JS class */
  #{{ section_id }} .cs-card.is-center {
    height: var(--cs-card-height-center);
  }

  #{{ section_id }} .cs-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }

  #{{ section_id }} .cs-card:hover img {
    transform: scale(1.05);
  }

  /* ── Card overlay gradient ── */
  #{{ section_id }} .cs-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);
  }

  /* ── Card content ── */
  #{{ section_id }} .cs-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px 22px;
    z-index: 2;
  }

  #{{ section_id }} .cs-card__title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--cs-title-size);
    font-weight: 700;
    color: var(--cs-title-color);
    margin: 0 0 14px;
    line-height: 1.25;
    text-shadow: 0 1px 6px rgba(0,0,0,0.3);
  }

  #{{ section_id }} .cs-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--cs-btn-bg);
    color: var(--cs-btn-color);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 4px;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  #{{ section_id }} .cs-card__btn:hover {
    opacity: 0.85;
    transform: translateX(3px);
  }

  #{{ section_id }} .cs-card__btn svg {
    width: 20px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  /* ── Placeholder ── */
  #{{ section_id }} .cs-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e0d8, #d0c8c0);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #{{ section_id }} .cs-card__placeholder svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    #{{ section_id }} {
      --cs-heading-size:   {{ section.settings.heading_size_mobile }}px;
      --cs-accent-size:    {{ section.settings.accent_size_mobile }}px;
      --cs-card-gap:       {{ section.settings.card_gap_mobile }}px;
      --cs-pt:             {{ section.settings.padding_top_mobile }}px;
      --cs-pb:             {{ section.settings.padding_bottom_mobile }}px;
      --cs-cards-desktop:  {{ section.settings.cards_visible_mobile }};
      --cs-card-title-size: {{ section.settings.card_title_size_mobile }}px;
    }

    #{{ section_id }} .cs-card__title {
      font-size: {{ section.settings.card_title_size_mobile }}px;
    }

    #{{ section_id }} .cs-arrow {
      width: 36px;
      height: 36px;
    }

    #{{ section_id }} .cs-inner {
      padding: 0 16px;
    }
  }
</style>

<div id="{{ section_id }}">
  <div class="cs-section">
    <div class="cs-inner">

      <!-- Header -->
      <div class="cs-header">
        <div class="cs-headings">
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="cs-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
          {%- endif -%}
          {%- if section.settings.accent_heading != blank -%}
            <p class="cs-accent">{{ section.settings.accent_heading }}</p>
          {%- endif -%}
        </div>

        <div class="cs-arrows">
          <button class="cs-arrow cs-arrow--prev" id="cs-prev-{{ section.id }}" aria-label="Previous">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="cs-arrow cs-arrow--next" id="cs-next-{{ section.id }}" aria-label="Next">
            <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
          </button>
        </div>
      </div>

      <!-- Slider -->
      <div class="cs-viewport" id="cs-viewport-{{ section.id }}">
        <div class="cs-track" id="cs-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- liquid
              case block.settings.link_type
                when 'product'
                  assign card_url = block.settings.link_product.url
                when 'collection'
                  assign card_url = block.settings.link_collection.url
                when 'page'
                  assign card_url = block.settings.link_page.url
                when 'url'
                  assign card_url = block.settings.link_url
                else
                  assign card_url = '#'
              endcase
              if card_url == blank
                assign card_url = '#'
              endif
            -%}
            <a
              class="cs-card"
              href="{{ card_url }}"
              {{ block.shopify_attributes }}
              {% if block.settings.link_new_tab %}target="_blank" rel="noopener"{% endif %}
            >
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="cs-card__placeholder">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {%- endif -%}

              <div class="cs-card__overlay"></div>

              <div class="cs-card__content">
                {%- if block.settings.title != blank -%}
                  <h3 class="cs-card__title">{{ block.settings.title }}</h3>
                {%- endif -%}

                {%- if block.settings.btn_label != blank -%}
                  <span class="cs-card__btn">
                    {{ block.settings.btn_label }}
                    <svg viewBox="0 0 24 14"><line x1="0" y1="7" x2="20" y2="7"/><polyline points="14 1 20 7 14 13"/></svg>
                  </span>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  var sectionEl  = document.getElementById('{{ section_id }}');
  var track      = document.getElementById('cs-track-{{ section.id }}');
  var viewport   = document.getElementById('cs-viewport-{{ section.id }}');
  var btnPrev    = document.getElementById('cs-prev-{{ section.id }}');
  var btnNext    = document.getElementById('cs-next-{{ section.id }}');
  if (!track || !viewport || !btnPrev || !btnNext) return;

  var currentIndex = 0;

  var settingsCenterCard = {{ section.settings.center_card_taller | json }};

  /* ── Get number of visible cards from CSS var ── */
  function getVisible() {
    return parseInt(getComputedStyle(sectionEl).getPropertyValue('--cs-cards-desktop').trim()) || 3;
  }

  /* ── Total cards ── */
  function getTotal() {
    return track.querySelectorAll('.cs-card').length;
  }

  /* ── Apply center-card taller class ── */
  function applyCenterClass() {
    if (!settingsCenterCard) return;
    var cards   = track.querySelectorAll('.cs-card');
    var visible = getVisible();
    var centerOffset = Math.floor(visible / 2);
    var centerIdx    = currentIndex + centerOffset;

    cards.forEach(function(card, i) {
      card.classList.toggle('is-center', i === centerIdx);
    });
  }

  /* ── Move track ── */
  function goTo(index) {
    var cards   = track.querySelectorAll('.cs-card');
    var total   = cards.length;
    var visible = getVisible();

    var maxIndex = Math.max(0, total - visible);
    currentIndex = Math.max(0, Math.min(index, maxIndex));

    var gap     = parseInt(getComputedStyle(track).gap) || 0;
    var cardW   = cards[0] ? cards[0].getBoundingClientRect().width : 0;
    var offset  = currentIndex * (cardW + gap);

    track.style.transform = 'translateX(-' + offset + 'px)';

    applyCenterClass();
    updateArrows();
  }

  /* ── Arrow states ── */
  function updateArrows() {
    var total   = getTotal();
    var visible = getVisible();
    btnPrev.classList.toggle('is-disabled', currentIndex === 0);
    btnNext.classList.toggle('is-disabled', currentIndex >= total - visible);
  }

  btnPrev.addEventListener('click', function() { goTo(currentIndex - 1); });
  btnNext.addEventListener('click', function() { goTo(currentIndex + 1); });

  /* ── Touch / swipe ── */
  var touchStartX = 0;
  viewport.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  viewport.addEventListener('touchend', function(e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) {
      goTo(diff > 0 ? currentIndex + 1 : currentIndex - 1);
    }
  }, { passive: true });

  /* ── Resize ── */
  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() { goTo(currentIndex); }, 150);
  });

  /* ── Init ── */
  goTo(0);
})();
</script>

{% schema %}
{
  "name": "Category Slider",
  "tag": "section",
  "class": "cs-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section max-width",
      "options": [
        { "value": "100%",   "label": "Full width" },
        { "value": "1600px", "label": "Extra wide (1600px)" },
        { "value": "1400px", "label": "Wide (1400px)" },
        { "value": "1200px", "label": "Standard (1200px)" },
        { "value": "1000px", "label": "Narrow (1000px)" }
      ],
      "default": "1400px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top — desktop (px)",
      "min": 0, "max": 120, "step": 4, "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom — desktop (px)",
      "min": 0, "max": 120, "step": 4, "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top — mobile (px)",
      "min": 0, "max": 80, "step": 4, "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom — mobile (px)",
      "min": 0, "max": 80, "step": 4, "default": 32
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading line 1",
      "default": "Populære"
    },
    {
      "type": "text",
      "id": "accent_heading",
      "label": "Heading line 2 (accent / italic)",
      "default": "Gave Kategorier!"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color (line 1)",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent heading color (line 2)",
      "default": "#8B6914"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size — desktop (px)",
      "min": 16, "max": 72, "step": 2, "default": 32
    },
    {
      "type": "range",
      "id": "accent_size",
      "label": "Accent heading font size — desktop (px)",
      "min": 16, "max": 72, "step": 2, "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading font size — mobile (px)",
      "min": 14, "max": 48, "step": 2, "default": 22
    },
    {
      "type": "range",
      "id": "accent_size_mobile",
      "label": "Accent heading font size — mobile (px)",
      "min": 14, "max": 48, "step": 2, "default": 22
    },
    {
      "type": "range",
      "id": "heading_bottom_gap",
      "label": "Gap between heading and cards (px)",
      "min": 0, "max": 80, "step": 4, "default": 32
    },
    {
      "type": "header",
      "content": "Navigation Arrows"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "arrow_border_color",
      "label": "Arrow border color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "cards_visible_desktop",
      "label": "Cards visible — desktop",
      "min": 1, "max": 6, "step": 1, "default": 3
    },
    {
      "type": "range",
      "id": "cards_visible_mobile",
      "label": "Cards visible — mobile",
      "min": 1, "max": 3, "step": 1, "default": 1
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height (px)",
      "min": 200, "max": 800, "step": 10, "default": 420
    },
    {
      "type": "range",
      "id": "card_height_center",
      "label": "Center card height — taller (px)",
      "min": 200, "max": 900, "step": 10, "default": 530,
      "info": "Only applies when 'Make center card taller' is enabled"
    },
    {
      "type": "checkbox",
      "id": "center_card_taller",
      "label": "Make center card taller",
      "default": true
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards — desktop (px)",
      "min": 0, "max": 60, "step": 2, "default": 16
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "label": "Gap between cards — mobile (px)",
      "min": 0, "max": 40, "step": 2, "default": 10
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius (px)",
      "min": 0, "max": 40, "step": 2, "default": 12
    },
    {
      "type": "header",
      "content": "Card Text & Button"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card title font size — desktop (px)",
      "min": 12, "max": 48, "step": 2, "default": 26
    },
    {
      "type": "range",
      "id": "card_title_size_mobile",
      "label": "Card title font size — mobile (px)",
      "min": 12, "max": 36, "step": 2, "default": 20
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#1a1a2e"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card title",
          "default": "Category Name"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },
        {
          "type": "header",
          "content": "Link"
        },
        {
          "type": "select",
          "id": "link_type",
          "label": "Link type",
          "options": [
            { "value": "none",       "label": "No link" },
            { "value": "product",    "label": "Product" },
            { "value": "collection", "label": "Collection" },
            { "value": "page",       "label": "Page" },
            { "value": "url",        "label": "Custom URL" }
          ],
          "default": "none"
        },
        {
          "type": "product",
          "id": "link_product",
          "label": "Product"
        },
        {
          "type": "collection",
          "id": "link_collection",
          "label": "Collection"
        },
        {
          "type": "page",
          "id": "link_page",
          "label": "Page"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Custom URL"
        },
        {
          "type": "checkbox",
          "id": "link_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Slider",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
