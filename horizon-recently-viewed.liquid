{% doc %}
  Recently Viewed Products Section
  - Slider layout with navigation arrows inline with heading
  - Uses Horizon product card (_product-card block)
  - Fully responsive with configurable columns
  - Schema settings: padding, background, heading font/color, products per view
{% enddoc %}

{% assign section_id = section.id %}
{% assign heading = section.settings.heading %}
{% assign products_to_show = section.settings.products_to_show %}
{% assign columns_desktop = section.settings.columns_desktop %}
{% assign columns_tablet = section.settings.columns_tablet %}
{% assign columns_mobile = section.settings.columns_mobile %}

<style>
  #recently-viewed-{{ section_id }} {
    background-color: {{ section.settings.background_color }};

    /* Desktop padding */
    --rv-padding-block-start: {{ section.settings.padding_top }}px;
    --rv-padding-block-end: {{ section.settings.padding_bottom }}px;

    padding-block-start: var(--rv-padding-block-start);
    padding-block-end: var(--rv-padding-block-end);
  }

  @media screen and (max-width: 749px) {
    #recently-viewed-{{ section_id }} {
      --rv-padding-block-start: {{ section.settings.padding_top_mobile }}px;
      --rv-padding-block-end: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  #recently-viewed-{{ section_id }} .rv-inner {
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* Header row */
  #recently-viewed-{{ section_id }} .rv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 1.5rem;
  }

  #recently-viewed-{{ section_id }} .rv-heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    font-weight: 600;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    #recently-viewed-{{ section_id }} .rv-heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  /* Navigation arrows */
  #recently-viewed-{{ section_id }} .rv-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  #recently-viewed-{{ section_id }} .rv-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid currentColor;
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
    color: {{ section.settings.heading_color }};
    transition: background 0.2s ease, color 0.2s ease, opacity 0.2s ease;
    padding: 0;
  }

  #recently-viewed-{{ section_id }} .rv-nav-btn:hover:not(:disabled) {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
  }

  #recently-viewed-{{ section_id }} .rv-nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  #recently-viewed-{{ section_id }} .rv-nav-btn svg {
    width: 1rem;
    height: 1rem;
    display: block;
  }

  /* Slider viewport */
  #recently-viewed-{{ section_id }} .rv-slider-wrapper {
    overflow: hidden;
  }

  #recently-viewed-{{ section_id }} .rv-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(
      (100% - ({{ columns_desktop }} - 1) * var(--rv-gap, 1.25rem)) / {{ columns_desktop }}
    );
    gap: var(--rv-gap, 1.25rem);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    --rv-gap: 1.25rem;
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #recently-viewed-{{ section_id }} .rv-track {
      grid-auto-columns: calc(
        (100% - ({{ columns_tablet }} - 1) * var(--rv-gap)) / {{ columns_tablet }}
      );
    }
  }

  @media screen and (max-width: 749px) {
    #recently-viewed-{{ section_id }} .rv-track {
      grid-auto-columns: calc(
        (100% - ({{ columns_mobile }} - 1) * var(--rv-gap)) / {{ columns_mobile }}
      );
      --rv-gap: 0.75rem;
    }
  }

  /* Individual card wrapper */
  #recently-viewed-{{ section_id }} .rv-card-item {
    min-width: 0;
  }

  /* Empty state */
  #recently-viewed-{{ section_id }} .rv-empty {
    text-align: center;
    padding: 2rem;
    color: {{ section.settings.heading_color }};
    opacity: 0.5;
    font-size: 0.95rem;
  }

  /* Hide section until JS populates it */
  #recently-viewed-{{ section_id }}.rv-hidden {
    display: none;
  }
</style>

<section
  id="recently-viewed-{{ section_id }}"
  class="recently-viewed-section rv-hidden"
  data-section-id="{{ section_id }}"
  data-products-to-show="{{ products_to_show }}"
  data-columns-desktop="{{ columns_desktop }}"
  data-columns-tablet="{{ columns_tablet }}"
  data-columns-mobile="{{ columns_mobile }}"
>
  <div class="rv-inner">
    <div class="rv-header">
      {% if heading != blank %}
        <h2 class="rv-heading">{{ heading | escape }}</h2>
      {% endif %}
      <div class="rv-nav" role="group" aria-label="{{ 'sections.recently_viewed.navigation' | t }}">
        <button
          class="rv-nav-btn rv-nav-btn--prev"
          aria-label="{{ 'sections.recently_viewed.previous' | t }}"
          disabled
        >
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          class="rv-nav-btn rv-nav-btn--next"
          aria-label="{{ 'sections.recently_viewed.next' | t }}"
        >
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="rv-slider-wrapper" aria-label="{{ 'sections.recently_viewed.title' | t }}" role="region">
      <ul class="rv-track" id="rv-track-{{ section_id }}" aria-live="polite">
        {{- /* Cards are injected by JS */ -}}
      </ul>
    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  const STORAGE_KEY = 'recently_viewed_products';
  const MAX_STORE = 20;

  // ---------- 1. Record current product ----------
  {% if product %}
  (function recordProduct() {
    const entry = {
      id: {{ product.id }},
      handle: {{ product.handle | json }},
      title: {{ product.title | json }},
      url: {{ product.url | json }},
      price: {{ product.price }},
      compare_at_price: {{ product.compare_at_price | default: 0 }},
      available: {{ product.available }},
      image: {{ product.featured_media.preview_image | image_url: width: 600 | json }},
      vendor: {{ product.vendor | json }},
    };
    try {
      let list = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      list = list.filter(p => p.id !== entry.id);
      list.unshift(entry);
      if (list.length > MAX_STORE) list = list.slice(0, MAX_STORE);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    } catch (e) {}
  })();
  {% endif %}

  // ---------- 2. Render section ----------
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.getElementById('recently-viewed-{{ section_id }}');
    if (!section) return;

    const productsToShow = parseInt(section.dataset.productsToShow, 10) || 8;
    const columnsDesktop = parseInt(section.dataset.columnsDesktop, 10) || 4;
    const columnsTablet = parseInt(section.dataset.columnsTablet, 10) || 3;
    const columnsMobile = parseInt(section.dataset.columnsMobile, 10) || 2;

    let list = [];
    try {
      list = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch (e) {}

    // Exclude the current product from display
    {% if product %}
    list = list.filter(p => p.id !== {{ product.id }});
    {% endif %}

    list = list.slice(0, productsToShow);

    if (list.length === 0) return; // Keep section hidden

    section.classList.remove('rv-hidden');

    const track = document.getElementById('rv-track-{{ section_id }}');
    const prevBtn = section.querySelector('.rv-nav-btn--prev');
    const nextBtn = section.querySelector('.rv-nav-btn--next');

    // Build cards
    list.forEach(function (p) {
      const li = document.createElement('li');
      li.className = 'rv-card-item';
      li.innerHTML = buildCard(p);
      track.appendChild(li);
    });

    // ---------- 3. Slider logic ----------
    let currentIndex = 0;

    function getColumnsVisible() {
      const w = window.innerWidth;
      if (w <= 749) return columnsMobile;
      if (w <= 989) return columnsTablet;
      return columnsDesktop;
    }

    function getMaxIndex() {
      return Math.max(0, list.length - getColumnsVisible());
    }

    function updateSlider() {
      const cols = getColumnsVisible();
      const gap = window.innerWidth <= 749 ? 12 : 20; // px, matches CSS var
      const trackWidth = track.parentElement.offsetWidth;
      const cardWidth = (trackWidth - gap * (cols - 1)) / cols;
      const offset = currentIndex * (cardWidth + gap);
      track.style.transform = 'translateX(-' + offset + 'px)';
      prevBtn.disabled = currentIndex <= 0;
      nextBtn.disabled = currentIndex >= getMaxIndex();
    }

    prevBtn.addEventListener('click', function () {
      if (currentIndex > 0) {
        currentIndex--;
        updateSlider();
      }
    });

    nextBtn.addEventListener('click', function () {
      if (currentIndex < getMaxIndex()) {
        currentIndex++;
        updateSlider();
      }
    });

    window.addEventListener('resize', function () {
      currentIndex = Math.min(currentIndex, getMaxIndex());
      updateSlider();
    });

    updateSlider();
  });

  // ---------- 4. Card HTML builder ----------
  function buildCard(p) {
    const price = formatMoney(p.price);
    const comparePrice = p.compare_at_price > p.price ? formatMoney(p.compare_at_price) : null;
    const onSale = comparePrice !== null;
    const soldOut = !p.available;

    const badgeHtml = soldOut
      ? '<span class="rv-badge rv-badge--sold-out">{{ "products.product.sold_out" | t }}</span>'
      : onSale
        ? '<span class="rv-badge rv-badge--sale">{{ "products.product.on_sale" | t }}</span>'
        : '';

    const imageHtml = p.image
      ? '<img src="' + p.image + '" alt="' + escapeHtml(p.title) + '" loading="lazy" width="600" height="600" class="rv-card__img">'
      : '<div class="rv-card__img-placeholder"></div>';

    return [
      '<div class="rv-product-card product-card size-style">',
        '<a href="' + p.url + '" class="rv-card__link" aria-label="' + escapeHtml(p.title) + '">',
          '<div class="rv-card__media">',
            badgeHtml,
            imageHtml,
          '</div>',
          '<div class="rv-card__info">',
            '<p class="rv-card__vendor">' + escapeHtml(p.vendor) + '</p>',
            '<p class="rv-card__title">' + escapeHtml(p.title) + '</p>',
            '<div class="rv-card__price">',
              onSale
                ? '<span class="rv-card__price--sale">' + price + '</span><s class="rv-card__price--compare">' + comparePrice + '</s>'
                : '<span class="rv-card__price--regular">' + price + '</span>',
            '</div>',
          '</div>',
        '</a>',
      '</div>'
    ].join('');
  }

  function formatMoney(cents) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(cents);
    }
    return (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
})();
</script>

<style>
  /* Product card styles matching Horizon theme */
  #recently-viewed-{{ section_id }} .rv-product-card {
    height: 100%;
  }

  #recently-viewed-{{ section_id }} .rv-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  #recently-viewed-{{ section_id }} .rv-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: var(--border-radius-base, 0.375rem);
    margin-block-end: 0.75rem;
  }

  #recently-viewed-{{ section_id }} .rv-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  #recently-viewed-{{ section_id }} .rv-card__link:hover .rv-card__img {
    transform: scale(1.04);
  }

  #recently-viewed-{{ section_id }} .rv-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: #ebebeb;
  }

  #recently-viewed-{{ section_id }} .rv-badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 1;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.2em 0.5em;
    border-radius: 2px;
  }

  #recently-viewed-{{ section_id }} .rv-badge--sale {
    background: #000;
    color: #fff;
  }

  #recently-viewed-{{ section_id }} .rv-badge--sold-out {
    background: #888;
    color: #fff;
  }

  #recently-viewed-{{ section_id }} .rv-card__info {
    padding-inline: 0.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  #recently-viewed-{{ section_id }} .rv-card__vendor {
    font-size: 0.75rem;
    color: #888;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  #recently-viewed-{{ section_id }} .rv-card__title {
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.3;
    font-weight: 500;
  }

  #recently-viewed-{{ section_id }} .rv-card__price {
    margin-block-start: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }

  #recently-viewed-{{ section_id }} .rv-card__price--sale {
    font-weight: 600;
    color: #c0392b;
  }

  #recently-viewed-{{ section_id }} .rv-card__price--compare {
    color: #aaa;
    font-size: 0.82rem;
    font-weight: 400;
  }

  #recently-viewed-{{ section_id }} .rv-card__price--regular {
    font-weight: 500;
  }
</style>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "section",
  "class": "section-recently-viewed",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Maximum products to show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Grid Columns"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Heading Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (desktop)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & arrow color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Section Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed"
    }
  ]
}
{% endschema %}
