{% comment %}
  Hero Gallery Slider Section
  - Auto-smooth infinite loop slider
  - Cards overlap the banner (half inside / half outside)
  - Fully responsive (desktop + mobile)
  - All key properties editable from Customize
{% endcomment %}

{%- liquid
  assign section_id = 'hgs-' | append: section.id
  assign slide_duration = section.settings.slide_duration | times: 1000
  assign total_width = section.blocks.size | times: section.settings.card_width | plus: section.blocks.size | times: section.settings.card_gap
-%}

<style>
  #{{ section_id }} {
    --hgs-bg-color:           {{ section.settings.bg_color }};
    --hgs-heading-color:      {{ section.settings.heading_color }};
    --hgs-text-color:         {{ section.settings.text_color }};
    --hgs-heading-size:       {{ section.settings.heading_size }}px;
    --hgs-text-size:          {{ section.settings.text_size }}px;
    --hgs-card-width:         {{ section.settings.card_width }}px;
    --hgs-card-height:        {{ section.settings.card_height }}px;
    --hgs-card-gap:           {{ section.settings.card_gap }}px;
    --hgs-banner-height:      {{ section.settings.banner_height }}px;
    --hgs-card-overlap:       {{ section.settings.card_overlap }}px;
    --hgs-section-width:      {{ section.settings.section_width }};
    --hgs-pt:                 {{ section.settings.padding_top }}px;
    --hgs-pb:                 {{ section.settings.padding_bottom }}px;
    --hgs-cards-desktop:      {{ section.settings.cards_visible_desktop }};
    --hgs-cards-mobile:       {{ section.settings.cards_visible_mobile }};
    --hgs-duration:           {{ slide_duration }}ms;
    --hgs-border-radius:      {{ section.settings.card_border_radius }}px;
  }

  /* ── Wrapper ── */
  #{{ section_id }} .hgs-section {
    background-color: var(--hgs-bg-color);
    padding-top:    var(--hgs-pt);
    padding-bottom: 0;
    overflow: hidden;
    position: relative;
  }

  /* ── Max-width container ── */
  #{{ section_id }} .hgs-inner {
    max-width: var(--hgs-section-width);
    margin: 0 auto;
  }

  /* ── Banner ── */
  #{{ section_id }} .hgs-banner {
    position: relative;
    width: 100%;
    height: var(--hgs-banner-height);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
  }

  #{{ section_id }} .hgs-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  #{{ section_id }} .hgs-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
  }

  #{{ section_id }} .hgs-banner__content {
    position: relative;
    z-index: 2;
    padding: 0 20px;
    padding-bottom: calc(var(--hgs-card-overlap) + 10px);
  }

  #{{ section_id }} .hgs-banner__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--hgs-heading-size);
    font-weight: 700;
    color: var(--hgs-heading-color);
    margin: 0 0 12px;
    line-height: 1.2;
    text-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }

  #{{ section_id }} .hgs-banner__text {
    font-size: var(--hgs-text-size);
    color: var(--hgs-text-color);
    margin: 0;
    opacity: 0.9;
  }

  /* ── Slider track wrapper ── */
  #{{ section_id }} .hgs-slider-wrap {
    position: relative;
    z-index: 3;
    margin-top: calc(-1 * var(--hgs-card-overlap));
    padding-bottom: var(--hgs-pb);
    overflow: hidden;
    /* Extra side overflow hidden */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
  }

  /* ── Track (duplicated for infinite loop) ── */
  #{{ section_id }} .hgs-track {
    display: flex;
    align-items: flex-start;
    gap: var(--hgs-card-gap);
    width: max-content;
    will-change: transform;
    /* animation set by JS */
  }

  #{{ section_id }} .hgs-track.is-animating {
    animation: hgs-scroll-{{ section.id }} var(--hgs-duration) linear infinite;
  }

  #{{ section_id }} .hgs-track:hover {
    animation-play-state: paused;
  }

  @keyframes hgs-scroll-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(var(--hgs-total-width-neg)); }
  }

  /* ── Card ── */
  #{{ section_id }} .hgs-card {
    flex: 0 0 var(--hgs-card-width);
    width: var(--hgs-card-width);
    height: var(--hgs-card-height);
    border-radius: var(--hgs-border-radius);
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,0.18);
    display: block;
    text-decoration: none;
    transition: transform 0.35s cubic-bezier(.22,.68,0,1.2), box-shadow 0.35s ease;
    cursor: pointer;
  }

  #{{ section_id }} .hgs-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 16px 40px rgba(0,0,0,0.28);
  }

  #{{ section_id }} .hgs-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── Mobile Overrides ── */
  @media (max-width: 768px) {
    #{{ section_id }} {
      --hgs-heading-size: {{ section.settings.heading_size_mobile }}px;
      --hgs-text-size:    {{ section.settings.text_size_mobile }}px;
      --hgs-card-gap:     {{ section.settings.card_gap_mobile }}px;
      --hgs-pt:           {{ section.settings.padding_top_mobile }}px;
      --hgs-pb:           {{ section.settings.padding_bottom_mobile }}px;
    }

    /* Dynamically set card-width from JS for mobile */
    #{{ section_id }} .hgs-card {
      flex: 0 0 var(--hgs-card-width-mobile, 160px);
      width: var(--hgs-card-width-mobile, 160px);
    }
  }
</style>

<div id="{{ section_id }}">
  <div class="hgs-section">
    <div class="hgs-inner">

      <!-- Banner -->
      <div class="hgs-banner">
        {%- if section.settings.banner_image != blank -%}
          <img
            class="hgs-banner__bg"
            src="{{ section.settings.banner_image | image_url: width: 1800 }}"
            alt="{{ section.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="1800"
            height="{{ section.settings.banner_height }}"
          >
        {%- elsif section.settings.banner_image == blank -%}
          <div class="hgs-banner__bg" style="background: linear-gradient(135deg, #f8c8d4 0%, #f0a0b0 50%, #c8a0d0 100%);"></div>
        {%- endif -%}

        <div class="hgs-banner__overlay"></div>

        <div class="hgs-banner__content">
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="hgs-banner__heading">
              {{ section.settings.heading }}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}

          {%- if section.settings.subtext != blank -%}
            <p class="hgs-banner__text">{{ section.settings.subtext }}</p>
          {%- endif -%}
        </div>
      </div><!-- /banner -->

      <!-- Slider -->
      <div class="hgs-slider-wrap">
        <div class="hgs-track" id="hgs-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- liquid
              case block.settings.link_type
                when 'product'
                  assign card_url = block.settings.link_product.url
                when 'collection'
                  assign card_url = block.settings.link_collection.url
                when 'page'
                  assign card_url = block.settings.link_page.url
                when 'url'
                  assign card_url = block.settings.link_url
                else
                  assign card_url = '#'
              endcase
              if card_url == blank
                assign card_url = '#'
              endif
            -%}
            <a
              class="hgs-card"
              href="{{ card_url }}"
              {{ block.shopify_attributes }}
              {% if block.settings.link_new_tab %}target="_blank" rel="noopener"{% endif %}
              aria-label="{{ block.settings.image.alt | default: 'Gallery image' | escape }}"
            >
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="{{ section.settings.card_width }}"
                  height="{{ section.settings.card_height }}"
                >
              {%- else -%}
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#e8c8d8,#d0a0c0);display:flex;align-items:center;justify-content:center;">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      </div><!-- /slider -->

    </div><!-- /inner -->
  </div><!-- /section -->
</div>

<script>
(function() {
  var sectionEl  = document.getElementById('{{ section_id }}');
  var track      = document.getElementById('hgs-track-{{ section.id }}');
  if (!sectionEl || !track) return;

  var isMobile   = window.innerWidth <= 768;
  var settings   = {
    cardWidth:        {{ section.settings.card_width }},
    cardHeight:       {{ section.settings.card_height }},
    cardGap:          {{ section.settings.card_gap }},
    cardGapMobile:    {{ section.settings.card_gap_mobile }},
    cardsDesktop:     {{ section.settings.cards_visible_desktop }},
    cardsMobile:      {{ section.settings.cards_visible_mobile }},
    duration:         {{ slide_duration }},
  };

  /* ── Compute mobile card width from viewport ── */
  function getMobileCardWidth() {
    var vw     = window.innerWidth;
    var gap    = settings.cardGapMobile;
    var count  = settings.cardsMobile;
    return Math.floor((vw - gap * (count + 1)) / count);
  }

  /* ── Set card widths ── */
  function applyCardWidth() {
    var isM = window.innerWidth <= 768;
    var w   = isM ? getMobileCardWidth() : settings.cardWidth;
    var h   = isM
      ? Math.round(settings.cardHeight * (w / settings.cardWidth))
      : settings.cardHeight;

    if (isM) {
      sectionEl.style.setProperty('--hgs-card-width-mobile', w + 'px');
    }

    // Set height via CSS var
    sectionEl.style.setProperty('--hgs-card-height', h + 'px');
    return { w: w, gap: isM ? settings.cardGapMobile : settings.cardGap };
  }

  /* ── Build infinite loop by duplicating cards ── */
  function buildLoop() {
    // Remove old clones
    track.querySelectorAll('.hgs-clone').forEach(function(el){ el.remove(); });

    var origCards = Array.from(track.querySelectorAll('.hgs-card:not(.hgs-clone)'));
    if (origCards.length === 0) return;

    // Duplicate enough times to fill ~3x viewport
    var times = Math.ceil((window.innerWidth * 3) / (origCards.length * settings.cardWidth)) + 1;
    times = Math.max(times, 2);

    for (var t = 0; t < times; t++) {
      origCards.forEach(function(card) {
        var clone = card.cloneNode(true);
        clone.classList.add('hgs-clone');
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
      });
    }
  }

  /* ── Calculate total original-set width for animation keyframe ── */
  function setAnimation() {
    var isM  = window.innerWidth <= 768;
    var gap  = isM ? settings.cardGapMobile : settings.cardGap;
    var origCards = track.querySelectorAll('.hgs-card:not(.hgs-clone)');
    var count = origCards.length;

    // Re-read actual rendered card width
    var firstCard = track.querySelector('.hgs-card');
    var cardW = firstCard ? firstCard.getBoundingClientRect().width : settings.cardWidth;

    var totalW = count * cardW + count * gap;

    // Remove old keyframe rule if any
    var styleId = 'hgs-kf-{{ section.id }}';
    var old = document.getElementById(styleId);
    if (old) old.remove();

    var style = document.createElement('style');
    style.id  = styleId;
    style.textContent =
      '@keyframes hgs-scroll-{{ section.id }} {' +
        '0%   { transform: translateX(0); }' +
        '100% { transform: translateX(-' + totalW + 'px); }' +
      '}';
    document.head.appendChild(style);

    track.style.setProperty('--hgs-total-width-neg', '-' + totalW + 'px');

    // Reset animation
    track.classList.remove('is-animating');
    void track.offsetWidth; // reflow
    track.style.animationDuration = settings.duration + 'ms';
    track.classList.add('is-animating');
  }

  /* ── Init ── */
  function init() {
    applyCardWidth();
    buildLoop();
    // rAF to ensure layout is done before measuring
    requestAnimationFrame(function(){
      requestAnimationFrame(setAnimation);
    });
  }

  /* ── Pause on focus (accessibility) ── */
  track.addEventListener('focusin',  function(){ track.style.animationPlayState = 'paused'; });
  track.addEventListener('focusout', function(){ track.style.animationPlayState = 'running'; });

  /* ── Resize ── */
  var resizeTimer;
  window.addEventListener('resize', function(){
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(init, 200);
  });

  init();
})();
</script>

{% schema %}
{
  "name": "Hero Gallery Slider",
  "tag": "section",
  "class": "hgs-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Banner / Background"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#fff8f8"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Banner overlay opacity (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner height (px)",
      "min": 200,
      "max": 700,
      "step": 10,
      "default": 360
    },
    {
      "type": "range",
      "id": "card_overlap",
      "label": "Card overlap into banner (px)",
      "min": 20,
      "max": 200,
      "step": 5,
      "default": 80
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section max-width",
      "options": [
        { "value": "100%",   "label": "Full width" },
        { "value": "1600px", "label": "Extra wide (1600px)" },
        { "value": "1400px", "label": "Wide (1400px)" },
        { "value": "1200px", "label": "Standard (1200px)" },
        { "value": "1000px", "label": "Narrow (1000px)" }
      ],
      "default": "100%"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section padding top (desktop, px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section padding bottom (desktop, px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Section padding top (mobile, px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Section padding bottom (mobile, px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "Heading & Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gled Dine Kjære Med Unike Gave!"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext / description",
      "default": "Utforsk vårt utvalg"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subtext color",
      "default": "#f5e8e8"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (desktop, px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 42
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Subtext font size (desktop, px)",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading font size (mobile, px)",
      "min": 16,
      "max": 52,
      "step": 2,
      "default": 26
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Subtext font size (mobile, px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "header",
      "content": "Image Cards"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width (desktop, px)",
      "min": 100,
      "max": 500,
      "step": 5,
      "default": 220
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height (desktop, px)",
      "min": 100,
      "max": 600,
      "step": 5,
      "default": 290
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Space between cards (desktop, px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "label": "Space between cards (mobile, px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "cards_visible_desktop",
      "label": "Cards visible on screen (desktop)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 6,
      "info": "Used as a visual guide; actual card width controls this precisely."
    },
    {
      "type": "range",
      "id": "cards_visible_mobile",
      "label": "Cards visible on screen (mobile)",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Slide animation duration (seconds for one full loop)",
      "min": 5,
      "max": 120,
      "step": 1,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Link"
        },
        {
          "type": "select",
          "id": "link_type",
          "label": "Link type",
          "options": [
            { "value": "none",       "label": "No link" },
            { "value": "product",    "label": "Product" },
            { "value": "collection", "label": "Collection" },
            { "value": "page",       "label": "Page" },
            { "value": "url",        "label": "Custom URL" }
          ],
          "default": "none"
        },
        {
          "type": "product",
          "id": "link_product",
          "label": "Product",
          "info": "Select when link type is 'Product'"
        },
        {
          "type": "collection",
          "id": "link_collection",
          "label": "Collection",
          "info": "Select when link type is 'Collection'"
        },
        {
          "type": "page",
          "id": "link_page",
          "label": "Page",
          "info": "Select when link type is 'Page'"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Custom URL",
          "info": "Enter when link type is 'Custom URL'"
        },
        {
          "type": "checkbox",
          "id": "link_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Gallery Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
